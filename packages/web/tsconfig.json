{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "node"],
    "rootDir": ".",
    "baseUrl": ".",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "Bundler"
  },
  "include": ["src", "vite.config.ts", "tailwind.config.ts", "postcss.config.cjs"]
}
