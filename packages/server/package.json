{
  "name": "@rpgfc/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/dev-server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/dev-server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate --config=drizzle.config.sqlite.ts && drizzle-kit generate --config=drizzle.config.pg.ts",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.11.0",
    "@hono/zod-validator": "^0.2.2",
    "@rpgfc/shared": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.30.10",
    "hono": "^4.4.0",
    "pg": "^8.12.0",
    "pino": "^9.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.22.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
